        "babel-loader": "^8.1.0",
        "css-loader": "^3.5.3",
        "html-loader": "^1.1.0",
        "html-webpack-plugin": "^4.3.0",
        "postcss-loader": "^3.0.0",
        "style-loader": "^1.2.1",
        "webpack": "^4.43.0",
        "webpack-cli": "^3.3.11",
        "webpack-dev-server": "^3.10.3",
        "webpack-merge": "^4.2.2"
    },
    "dependencies": {
